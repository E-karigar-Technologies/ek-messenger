rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    match /statuses/{statusId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAuthed() && resource.data.ownerUid == request.auth.uid;

      match /views/{viewerUid} {
        allow read: if isAuthed();
        allow create, update, delete: if isSelf(viewerUid);
      }

      match /replies/{replyId} {
        allow read: if isAuthed();
        allow create, update, delete: if isAuthed() && request.resource.data.viewerUid == request.auth.uid;
      }
    }

    match /statusPrivacyDefaults/{uid} {
      allow read, write: if isSelf(uid);
    }

    match /statusMutedByUser/{viewerUid}/owners/{ownerUid} {
      allow read, write: if isSelf(viewerUid);
    }

    match /statusHiddenByUser/{viewerUid}/owners/{ownerUid} {
      allow read, write: if isSelf(viewerUid);
    }
  }
}
